                        <a href="#" class="swiper-slide"><img src="foto/book7.jpg" alt=""></a>
                        <a href="#" class="swiper-slide"><img src="foto/book8.jpg" alt=""></a>
                        <a href="#" class="swiper-slide"><img src="foto/book9.jpg" alt=""></a>
                    </div>
                    <img src="foto/stand.png" class="stand" alt="">

                </div>
            </div>
        </section>

