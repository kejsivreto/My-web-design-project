    <body>
        <header class="header">
            <div class="header-1">
                <a href="file:///C:/Users/user/Desktop/PROJEKTI/FrontPage/fp_index.html" class="logo"> <i class="fa-solid fa-book-open"></i>BookBuzz</a>
                <form action="" class="search-form">
                    <input type="search" name="" placeholder="search here..." id="search-box">
                    <label for="search-box" class="fas fa-search"></label>
                </form>

                <div class="icons">
                    <div id="search-btn" class="fas fa-search"></div>
                    <a href="#" class="fas fa-heart"></a>
                    <div class="shoopingBasket">
                        <i class="fas fa-shopping-cart"></i>
                        <span>0</span>
                    </div>
                    <div id="login-btn" class="fas fa-user"></div>
                </div>

            </div>

            <div class="header-2">
                <nav class="navbar">
                    <a href="#home">Home</a>
                    <a href="#services">About</a>
                    <a href="#category">Categories</a>
                    <a href="#featured">Trending</a>
                    <a href="#authors">Authors</a>
                    <a href="#testimonials">Reviews</a>
                    <a href="#footer">Contact</a>
                </nav>
            </div>

        </header>

        <nav class="bottom-navbar">
            <a href="#home" class="fas fa-home"></a>
            <a href="#services" class="fa-solid fa-circle-info"></a>
            <a href="#category" class="fa-solid fa-list"></a>
            <a href="#featured" class="fa-solid fa-layer-group"></a>
            <a href="#authors" class="fa-solid fa-pen"></a>
