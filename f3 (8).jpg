<!-- ~Shooping-Cart -->
<div class="sidebar" id="sidebar">
            
    <div class="sidebar-close">
        <i class="fa-solid fa-close"></i>
    </div>
    
    <div class="cart-menu">
        <h3>My Cart</h3>
        <div class="cart-tems">test 1</div>
    </div>

